<Window
    x:Class="AINewsPipeline.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AINewsPipeline.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AI新闻自动化系统"
    Width="1200"
    Height="800"
    MinWidth="1024"
    MinHeight="768">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Left"
            IsPaneToggleButtonVisible="True"
            IsBackButtonVisible="Collapsed"
            Header="AI新闻自动化系统"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="NavCollect"
                    Content="采集"
                    Icon="Download">
                    <NavigationViewItem.Tag>Collect</NavigationViewItem.Tag>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavArticles"
                    Content="文章管理"
                    Icon="Document">
                    <NavigationViewItem.Tag>Articles</NavigationViewItem.Tag>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavPublish"
                    Content="发布"
                    Icon="Upload">
                    <NavigationViewItem.Tag>Publish</NavigationViewItem.Tag>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    x:Name="NavSettings"
                    Content="设置"
                    Icon="Settings">
                    <NavigationViewItem.Tag>Settings</NavigationViewItem.Tag>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="0">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>

        <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundAccentBrush}" Height="32">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="12,0">
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>