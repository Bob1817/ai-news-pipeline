<Page
    x:Class="AINewsPipeline.WinUI.Views.CollectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AINewsPipeline.WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="新闻采集配置" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="选择行业：" Width="120" VerticalAlignment="Center" />
                <ComboBox x:Name="IndustryComboBox" Width="200" PlaceholderText="请选择行业">
                    <ComboBoxItem>科技</ComboBoxItem>
                    <ComboBoxItem>财经</ComboBoxItem>
                    <ComboBoxItem>娱乐</ComboBoxItem>
                    <ComboBoxItem>体育</ComboBoxItem>
                    <ComboBoxItem>教育</ComboBoxItem>
                    <ComboBoxItem>医疗</ComboBoxItem>
                    <ComboBoxItem>汽车</ComboBoxItem>
                    <ComboBoxItem>房产</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="关键词：" Width="120" VerticalAlignment="Center" />
                <TextBox x:Name="KeywordsTextBox" Width="400" PlaceholderText="多个关键词用逗号分隔" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="采集数量：" Width="120" VerticalAlignment="Center" />
                <Slider x:Name="CountSlider" Minimum="5" Maximum="50" Value="10" Width="200" />
                <TextBlock x:Name="CountText" Text="10" Width="40" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="12" Margin="0,20,0,0">
            <TextBlock Text="采集源：" />
            <StackPanel Orientation="Horizontal" Spacing="20">
                <ToggleSwitch x:Name="NewsSourceToggle" Header="新闻网站" IsOn="True" />
                <ToggleSwitch x:Name="BaiduToggle" Header="百度百科" IsOn="True" />
                <ToggleSwitch x:Name="WeiboToggle" Header="微博热点" IsOn="False" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="3" Margin="0,20,0,0">
            <StackPanel x:Name="LogPanel" Orientation="Vertical" Spacing="4" />
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,20,0,0">
            <Button x:Name="StartButton" Content="开始采集" Click="StartButton_Click" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="StopButton" Content="停止采集" Click="StopButton_Click" IsEnabled="False" />
        </StackPanel>
    </Grid>
</Page>