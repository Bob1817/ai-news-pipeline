<Page
    x:Class="AINewsPipeline.WinUI.Views.PublishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="发布管理">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="发布管理" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20">
            <StackPanel Orientation="Vertical" Width="200">
                <TextBlock Text="选择发布平台：" Margin="0,0,0,8" />
                <ListView x:Name="PlatformListView" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:PlatformItem">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="PlatformCheckBox_Checked" Unchecked="PlatformCheckBox_Unchecked" />
                                <TextBlock Text="{x:Bind Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel Orientation="Vertical" Width="300">
                <TextBlock Text="待发布文章：" Margin="0,0,0,8" />
                <ListView x:Name="ArticlesListView" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ArticleItem">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="ArticleCheckBox_Checked" Unchecked="ArticleCheckBox_Unchecked" />
                                <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="发布历史：" Margin="0,0,0,12" />
            <ListView x:Name="HistoryListView">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:PublishRecord">
                        <StackPanel Orientation="Horizontal" Spacing="12" Padding="8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                            <TextBlock Text="{x:Bind Title}" Width="300" />
                            <TextBlock Text="{x:Bind Platform}" Width="100" />
                            <TextBlock Text="{x:Bind PublishedAt}" Width="150" />
                            <TextBlock Text="{x:Bind Status}" Foreground="{x:Bind StatusBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,20,0,0">
            <Button x:Name="PublishButton" Content="批量发布" Click="PublishButton_Click" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="RefreshButton" Content="刷新" Click="RefreshButton_Click" />
        </StackPanel>
    </Grid>
</Page>