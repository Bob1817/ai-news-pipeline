<Page
    x:Class="AINewsPipeline.WinUI.Views.PublishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:AINewsPipeline.WinUI.Models"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="发布管理" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20">
            <StackPanel Orientation="Vertical" Width="200">
                <TextBlock Text="选择发布平台：" Margin="0,0,0,8" />
                <ListView x:Name="PlatformListView" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="PlatformCheckBox_Checked" Unchecked="PlatformCheckBox_Unchecked" />
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel Orientation="Vertical" Width="300">
                <TextBlock Text="待发布文章：" Margin="0,0,0,8" />
                <ListView x:Name="ArticlesListView" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="ArticleCheckBox_Checked" Unchecked="ArticleCheckBox_Unchecked" />
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="发布历史：" Margin="0,0,0,12" />
            <ListView x:Name="HistoryListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12" Padding="8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                            <TextBlock Text="{Binding Title}" Width="300" />
                            <TextBlock Text="{Binding Platform}" Width="100" />
                            <TextBlock Text="{Binding PublishedAt}" Width="150" />
                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,20,0,0">
            <Button x:Name="PublishButton" Content="批量发布" Click="PublishButton_Click" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="RefreshButton" Content="刷新" Click="RefreshButton_Click" />
        </StackPanel>
    </Grid>
</Page>
